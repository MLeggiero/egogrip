# --- Python (pipeline) ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Unity (app) ---
app/Library/
app/Temp/
app/Obj/
app/obj/
app/Build/
app/Builds/
app/Logs/
app/UserSettings/
app/MemoryCaptures/
app/.utmp/
app/.vs/
app/sysinfo.txt
app/*.csproj
app/*.sln
app/.vsconfig
# Unity-generated signing key — never commit a keystore
app/user.keystore
app/*.keystore
# PICO Unity Integration SDK (~300 MB, proprietary) — NOT committed. After cloning, unzip the
# downloaded SDK (v3.4.0) into app/Packages/com.unity.xr.picoxr/ so its package.json sits there;
# Unity loads it as an embedded package (see docs/UNITY_POSE_SETUP.md and app/Packages/PICOXR_SDK_REQUIRED.md).
# The first pattern also ignores stray extracted SDK archive folders left elsewhere under app/.
app/PICO Unity Integration SDK*/
app/Packages/com.unity.xr.picoxr/

# --- Android / Gradle (native-plugin, app build) ---
.gradle/
**/build/
local.properties
# *.apk - uploading any built apps
*.aab
*.aar.bak

# --- Firmware build artifacts ---
firmware/**/build/
*.uf2
*.elf
*.bin.tmp

# --- Captured data: never commit episodes ---
data/
episodes/
_demo_out/
*.mp4
*.h264
*.bag

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
