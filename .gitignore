# --- Python (pipeline) ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Unity (app) ---
app/Library/
app/Temp/
app/Obj/
app/obj/
app/Build/
app/Builds/
app/Logs/
app/UserSettings/
app/MemoryCaptures/
app/.utmp/
app/.vs/
app/sysinfo.txt
app/*.csproj
app/*.sln
app/.vsconfig
# Unity-generated signing key — never commit a keystore
app/user.keystore
app/*.keystore
# stray extracted SDK archives
app/PICO Unity Integration SDK*/
# Vendored PICO Unity Integration SDK (proprietary, ~300 MB) — NOT committed.
# Re-add by copying the downloaded SDK into app/Packages/com.unity.xr.picoxr/
# (see docs/UNITY_POSE_SETUP.md). Unity auto-detects it as an embedded package.
app/Packages/com.unity.xr.picoxr/

# --- Android / Gradle (native-plugin, app build) ---
.gradle/
**/build/
local.properties
*.apk
*.aab
*.aar.bak

# --- Firmware build artifacts ---
firmware/**/build/
*.uf2
*.elf
*.bin.tmp

# --- Captured data: never commit episodes ---
data/
episodes/
_demo_out/
*.mp4
*.h264
*.bag

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
